<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SHYDLE</title>
    <meta name="webpage-version" content="__WEBPAGE_VERSION__" />
    <link rel="stylesheet" href="./styles.css?v=__WEBPAGE_VERSION__" />
  </head>
  <body>
    <main class="app">
      <h1 class="app-title">SHYDLE</h1>

      <section class="game-shell" aria-label="Wordle game">
        <div class="play-area">
          <div class="board-frame">
            <div id="board" class="board" aria-label="Guess board"></div>
          </div>

          <div class="side-panel-stack">
            <div class="keyboard-frame">
              <div
                id="keyboard"
                class="keyboard"
                aria-label="On-screen keyboard"
              ></div>
              <div class="keyboard-actions" aria-label="Keyboard actions">
                <button
                  id="clear-row-button"
                  class="keyboard-action keyboard-action-clear"
                  type="button"
                >
                  CLEAR
                </button>
                <button
                  id="backspace-key-button"
                  class="keyboard-action keyboard-action-backspace"
                  type="button"
                >
                  Backspace
                </button>
                <button
                  id="enter-key-button"
                  class="keyboard-action keyboard-action-enter"
                  type="button"
                >
                  Enter
                </button>
              </div>
            </div>

            <div class="button-frame">
              <div class="board-actions">
                <button id="hint-button" class="secondary-button" type="button">
                  HINT
                </button>
                <button id="new-game-button" class="new-game-button" type="button">
                  NEW GAME
                </button>
                <button
                  id="settings-button"
                  class="icon-button"
                  type="button"
                  aria-label="Settings"
                >
                  &#9881;
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <p class="asset-version">__WEBPAGE_VERSION__ __WEBPAGE_TIMESTAMP__</p>
    </main>

    <div
      id="confirm-modal"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="confirm-modal-title"
      aria-describedby="confirm-modal-text"
    >
      <div id="confirm-modal-backdrop" class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="confirm-modal-title" class="modal-title">Start new game?</h2>
        <p id="confirm-modal-text" class="modal-text">
          Your current progress will be lost.
        </p>
        <div class="modal-actions">
          <button id="confirm-cancel-button" class="modal-button modal-button-cancel" type="button">
            KEEP PLAYING
          </button>
          <button id="confirm-accept-button" class="modal-button modal-button-accept" type="button">
            NEW GAME
          </button>
        </div>
      </div>
    </div>

    <div
      id="reveal-modal"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="reveal-modal-title"
      aria-describedby="reveal-modal-text"
    >
      <div id="reveal-modal-backdrop" class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="reveal-modal-title" class="modal-title">The word was...</h2>
        <p id="reveal-modal-text" class="modal-text"></p>
        <div class="modal-actions">
          <button id="reveal-ok-button" class="modal-button modal-button-accept" type="button">
            NEW GAME
          </button>
        </div>
      </div>
    </div>

    <div
      id="settings-modal"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="settings-modal-title"
      aria-describedby="settings-modal-text"
    >
      <div id="settings-modal-backdrop" class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="settings-modal-title" class="modal-title">Settings</h2>
        <p id="settings-modal-text" class="modal-text">
          Choose the number of guesses.
        </p>
        <div class="settings-field">
          <label class="control-group" for="guess-count">
            <span class="control-label">Guesses</span>
            <select id="guess-count" class="control-input">
              <option value="2">2 - Extreme</option>
              <option value="3">3 - Brutal</option>
              <option value="4">4 - Spicy</option>
              <option value="5" selected>5 - Classic</option>
              <option value="6">6 - Chill</option>
              <option value="7">7 - Lame</option>
            </select>
          </label>
        </div>
        <div class="modal-actions">
          <button id="settings-close-button" class="modal-button modal-button-accept" type="button">
            CLOSE
          </button>
        </div>
      </div>
    </div>

    <div
      id="win-modal"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="win-modal-title"
      aria-describedby="win-modal-text"
    >
      <div id="win-modal-backdrop" class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="win-modal-title" class="modal-title">YOU WIN!</h2>
        <p id="win-modal-text" class="modal-text"></p>
        <div class="modal-actions">
          <button id="win-new-game-button" class="modal-button modal-button-accept" type="button">
            NEW GAME
          </button>
        </div>
      </div>
    </div>

    <div
      id="lose-modal"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="lose-modal-title"
      aria-describedby="lose-modal-text"
    >
      <div id="lose-modal-backdrop" class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="lose-modal-title" class="modal-title">SORRY YOU LOST.</h2>
        <p id="lose-modal-text" class="modal-text"></p>
        <div class="modal-actions">
          <button id="lose-new-game-button" class="modal-button modal-button-accept" type="button">
            NEW GAME
          </button>
        </div>
      </div>
    </div>

    <div
      id="no-more-hints-modal"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="no-more-hints-modal-title"
      aria-describedby="no-more-hints-modal-text"
    >
      <div id="no-more-hints-modal-backdrop" class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="no-more-hints-modal-title" class="modal-title">No more hints!</h2>
        <p id="no-more-hints-modal-text" class="modal-text">
          I&#39;ve told you all I can. It&#39;s up to you now!
        </p>
        <div class="modal-actions">
          <button id="no-more-hints-close-button" class="modal-button modal-button-accept" type="button">
            CLOSE
          </button>
        </div>
      </div>
    </div>

    <div
      id="error-screen"
      class="modal"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="error-screen-title"
      aria-describedby="error-screen-text"
    >
      <div class="modal-backdrop"></div>
      <div class="modal-panel">
        <h2 id="error-screen-title" class="modal-title">Unable to load words.</h2>
        <p id="error-screen-text" class="modal-text">Please reload the page.</p>
        <div class="modal-actions">
          <button id="error-screen-reload-button" class="modal-button modal-button-accept" type="button">
            RELOAD
          </button>
        </div>
      </div>
    </div>

    <script src="./script.js?v=__WEBPAGE_VERSION__"></script>
  </body>
</html>
